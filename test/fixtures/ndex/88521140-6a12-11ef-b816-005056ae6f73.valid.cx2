  {
    "networkAttributes": [
      {
        "name": "DNA Damage Association Score (DAS) network",
        "description": "<p>DNA Damage Association Score (DAS) network.</p><p>The multi-scale DNA Damage Response Assembly Map (DDRAM) is inferred from this network and can be accessed at <a href=\"http://ccmi.org/ddram\"><b>http://ccmi.org/ddram</b></a></p><p><b>Broad function</b><br/>Blue: Double-strand repair<br/>Green: Single-strand repair<br/>Rose: DNA replication<br/>Orange: Chromatin remodeling<br/>Violet: Post-replication repair</p>",
        "version": "1.0",
        "author": "Anton Kratz",
        "labels": "DNA damage response",
        "organism": "Human, 9606, H.sapiens",
        "rights": "Attribution-NonCommercial-ShareAlike 4.0 International (CC BY-NC-SA 4.0)",
        "rightsHolder": "University of California San Diego"
      }
    ]
  },
