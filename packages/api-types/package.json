{
  "name": "@cytoscape-web/api-types",
  "version": "1.0.0-beta.2",
  "description": "TypeScript type declarations for the Cytoscape Web App API",
  "types": "dist/index.d.ts",
  "main": "dist/index.d.ts",
  "files": [
    "dist",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs');fs.copyFileSync('src/mf-declarations.d.ts','dist/mf-declarations.d.ts');const p='dist/index.d.ts';const c=fs.readFileSync(p,'utf8');const r='/// <reference path=\\\"./mf-declarations.d.ts\\\" />\\n';if(!c.startsWith(r))fs.writeFileSync(p,r+c);\""
  },
  "keywords": [
    "cytoscape",
    "network",
    "visualization",
    "typescript",
    "types"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.4"
  }
}
