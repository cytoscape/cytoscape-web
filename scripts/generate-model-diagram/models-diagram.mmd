    %% Relationships - Network Layer
    Network --> Node
    Network --> Edge
    Node --> GraphObject
    Edge --> GraphObject
    GraphObject --> IdType
    
    %% Relationships - View Layer
    NetworkView --> View
    NetworkView --> NodeView
    NetworkView --> EdgeView
    NetworkView --> IdType
    NodeView --> View
    EdgeView --> View
    
    %% Relationships - Visual Style Layer
    VisualStyle --> VisualProperty
    VisualProperty --> VisualMappingFunction
    VisualProperty --> Property
    
    %% Relationships - Table Layer
    Table --> Column
    Column --> ValueType
    
    
    %% Relationships - Workspace
    Workspace --> IdType
    Workspace --> Network
    
    %% Relationships - Apps
    ServiceApp --> ServiceAppTask
    CyApp --> ServiceApp
    
    %% Relationships - Layout
    LayoutEngine --> LayoutAlgorithm
    
    %% Relationships - Filters
    Filter --> FilterConfig
    Filter --> Property
    
    %% Relationships - Renderer
    Renderer --> ViewPort
    Renderer --> NetworkView
    
    %% Relationships - Cx Import/Export
    NiceCx --> CxDescriptor
    NiceCx --> Network
